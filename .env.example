NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
USE_DATABASE=false  # Set to true to use PostgreSQL, false for JSON files
DB_HOST=localhost
DB_PORT=5432
DB_NAME=awyad_mes
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# API Configuration
API_BASE_URL=/api/v1
MAX_REQUEST_SIZE=10mb

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CSV Data Paths
DATA_DIR=./data
CSV_ENCODING=utf-8
